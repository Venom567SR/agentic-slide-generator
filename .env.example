# ============================================================================
# LLM Backend Configuration
# ============================================================================

# Toggle between Vertex AI and Developer API
# Set to "true" for Vertex AI (uses ADC), "false" for Developer API (uses API key)
USE_VERTEX=false

# --- Vertex AI Configuration (when USE_VERTEX=true) ---
# Requires: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Developer API Configuration (when USE_VERTEX=false) ---
# Get your API key from: https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================================
# External Service API Keys
# ============================================================================

# Notion integration
# Get from: https://www.notion.so/my-integrations
NOTION_API_KEY=your-notion-api-key-here

# Web search (optional - for future implementation)
# SERPER_API_KEY=your-serper-api-key-here
# GOOGLE_SEARCH_API_KEY=your-google-search-api-key-here
# GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

# ============================================================================
# Application Configuration
# ============================================================================

# Default generation mode (lite, lite_plus, standard, pro, max)
DEFAULT_MODE=standard

# API server settings
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
